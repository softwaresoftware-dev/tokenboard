{
  "name": "tokenboard",
  "description": "Token usage leaderboard \u2014 calculates Claude Code API cost equivalent and uploads to the public leaderboard at tokenboard.softwaresoftware.dev",
  "version": "1.0.0",
  "author": {
    "name": "NOV LLC",
    "url": "https://github.com/softwaresoftware-dev"
  },
  "repository": "https://github.com/softwaresoftware-dev/tokenboard",
  "keywords": [
    "tokens",
    "usage",
    "leaderboard",
    "stats",
    "cost"
  ],
  "mcpServers": {
    "tokenboard": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "${CLAUDE_PLUGIN_ROOT}",
        "python",
        "server.py"
      ],
      "cwd": "${CLAUDE_PLUGIN_ROOT}"
    }
  }
}
